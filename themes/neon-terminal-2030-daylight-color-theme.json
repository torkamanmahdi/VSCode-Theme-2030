  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#8A93A8", "fontStyle": "italic" }
    },
    {
      "name": "Keywords / control flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type.function.arrow",
        "punctuation.definition.keyword"
      ],
      "settings": { "foreground": "#D6006E" }
    },
    {
      "name": "Storage / modifiers (const, let, function, class)",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#C03A86", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#0E9E84" }
    },
    {
      "name": "Template / interpolation strings",
      "scope": ["string.template", "string.interpolated"],
      "settings": { "foreground": "#0C8C76" }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape", "constant.character"],
      "settings": { "foreground": "#B58A00" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#B5730A" }
    },
    {
      "name": "Booleans / language constants (null, true, undefined)",
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#D2543A", "fontStyle": "bold" }
    },
    {
      "name": "Constants / enum members",
      "scope": ["constant.other", "variable.other.constant", "entity.name.constant"],
      "settings": { "foreground": "#B5730A" }
    },
    {
      "name": "Functions / method calls",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": { "foreground": "#1273C9" }
    },
    {
      "name": "Function declarations",
      "scope": ["entity.name.function.member", "meta.definition.function entity.name.function"],
      "settings": { "foreground": "#0E63B0" }
    },
    {
      "name": "Classes / types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": { "foreground": "#8B43E0" }
    },
    {
      "name": "Built-in types / primitives",
      "scope": ["support.type.primitive", "keyword.type", "storage.type.built-in"],
      "settings": { "foreground": "#8B43E0", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#1E2738" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#C76A56", "fontStyle": "italic" }
    },
    {
      "name": "Object keys / properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#1E7BB0" }
    },
    {
      "name": "Language built-in variables (this, self, super)",
      "scope": ["variable.language", "variable.language.this", "variable.language.super"],
      "settings": { "foreground": "#D2543A", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "storage.type.operator"],
      "settings": { "foreground": "#0E8FB0" }
    },
    {
      "name": "Punctuation / delimiters",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": { "foreground": "#6A748A" }
    },
    {
      "name": "HTML / XML tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#D6006E" }
    },
    {
      "name": "HTML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#B58A00", "fontStyle": "italic" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css", "support.type.property-name.scss"],
      "settings": { "foreground": "#1273C9" }
    },
    {
      "name": "CSS values / units",
      "scope": ["support.constant.property-value.css", "keyword.other.unit.css"],
      "settings": { "foreground": "#0E9E84" }
    },
    {
      "name": "CSS classes / ids",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#8B43E0" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#1273C9" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#D6006E", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#B5730A", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#0E9E84", "fontStyle": "italic" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#1273C9", "fontStyle": "underline" }
    },
    {
      "name": "Markdown code / inline code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#0C8C76" }
    },
    {
      "name": "Markdown quotes",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6A748A", "fontStyle": "italic" }
    },
    {
      "name": "Decorators / annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#B58A00", "fontStyle": "italic" }
    },
    {
      "name": "Regular expressions",
      "scope": ["string.regexp", "constant.other.character-class.regexp"],
      "settings": { "foreground": "#C03A86" }
    },
    {
      "name": "Support / library functions",
      "scope": ["support.function.builtin", "support.constant"],
      "settings": { "foreground": "#0E8FB0" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#E11D48", "fontStyle": "underline" }
    },
    {
      "name": "Imports / module paths",
      "scope": ["keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": { "foreground": "#D6006E", "fontStyle": "italic" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#8B43E0",
    "class": "#8B43E0",
    "class.declaration": "#8B43E0",
    "interface": "#1E7BB0",
    "enum": "#8B43E0",
    "enumMember": "#B5730A",
    "type": "#8B43E0",
    "typeParameter": { "foreground": "#8B43E0", "fontStyle": "italic" },
    "struct": "#8B43E0",
    "function": "#1273C9",
    "function.declaration": "#0E63B0",
    "method": "#1273C9",
    "macro": "#B58A00",
    "variable": "#1E2738",
    "variable.readonly": "#B5730A",
    "variable.declaration": "#1E2738",
    "parameter": { "foreground": "#C76A56", "fontStyle": "italic" },
    "property": "#1E7BB0",
    "property.readonly": "#B5730A",
    "keyword": "#D6006E",
    "string": "#0E9E84",
    "number": "#B5730A",
    "operator": "#0E8FB0",
    "decorator": "#B58A00",
    "*.deprecated": { "strikethrough": true }
  }
}
