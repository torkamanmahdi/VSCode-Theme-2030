  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#47657A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords / control flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type.function.arrow",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#7AA5FF"
      }
    },
    {
      "name": "Storage / modifiers",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9DBEFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#4FE3D0"
      }
    },
    {
      "name": "Template / interpolation strings",
      "scope": [
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#7FF0E0"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape",
        "constant.character"
      ],
      "settings": {
        "foreground": "#A0E8FF"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#6BD5FF"
      }
    },
    {
      "name": "Booleans / language constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#8ED0C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants / enum members",
      "scope": [
        "constant.other",
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#6BD5FF"
      }
    },
    {
      "name": "Functions / method calls",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#5BB8FF"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function.member",
        "meta.definition.function entity.name.function"
      ],
      "settings": {
        "foreground": "#8ACDFF"
      }
    },
    {
      "name": "Classes / types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#B79DFF"
      }
    },
    {
      "name": "Built-in types / primitives",
      "scope": [
        "support.type.primitive",
        "keyword.type",
        "storage.type.built-in"
      ],
      "settings": {
        "foreground": "#B79DFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#CFE6F5"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#90C8D8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object keys / properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#9BDFF0"
      }
    },
    {
      "name": "Language built-in variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#8ED0C0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "storage.type.operator"
      ],
      "settings": {
        "foreground": "#6EE7FF"
      }
    },
    {
      "name": "Punctuation / delimiters",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#567488"
      }
    },
    {
      "name": "HTML / XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7AA5FF"
      }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A0E8FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#5BB8FF"
      }
    },
    {
      "name": "CSS values / units",
      "scope": [
        "support.constant.property-value.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#4FE3D0"
      }
    },
    {
      "name": "CSS classes / ids",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#B79DFF"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#5BB8FF"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#7AA5FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#6BD5FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#4FE3D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#5BB8FF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown code / inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#7FF0E0"
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7C97AD",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#A0E8FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#9DBEFF"
      }
    },
    {
      "name": "Support / library functions",
      "scope": [
        "support.function.builtin",
        "support.constant"
      ],
      "settings": {
        "foreground": "#6EE7FF"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B7D",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Imports / module paths",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#7AA5FF",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#B79DFF",
    "class": "#B79DFF",
    "class.declaration": "#B79DFF",
    "interface": "#C9BAFF",
    "enum": "#B79DFF",
    "enumMember": "#6BD5FF",
    "type": "#B79DFF",
    "typeParameter": {
      "foreground": "#B79DFF",
      "fontStyle": "italic"
    },
    "struct": "#B79DFF",
    "function": "#5BB8FF",
    "function.declaration": "#8ACDFF",
    "method": "#5BB8FF",
    "macro": "#A0E8FF",
    "variable": "#CFE6F5",
    "variable.readonly": "#6BD5FF",
    "variable.declaration": "#CFE6F5",
    "parameter": {
      "foreground": "#90C8D8",
      "fontStyle": "italic"
    },
    "property": "#9BDFF0",
    "property.readonly": "#6BD5FF",
    "keyword": "#7AA5FF",
    "string": "#4FE3D0",
    "number": "#6BD5FF",
    "operator": "#6EE7FF",
    "decorator": "#A0E8FF",
    "*.deprecated": {
      "strikethrough": true
    }
  }
}
