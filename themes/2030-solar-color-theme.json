  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#6B5A42",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords / control flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type.function.arrow",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#FF6B4A"
      }
    },
    {
      "name": "Storage / modifiers",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF8A6B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#E8C15A"
      }
    },
    {
      "name": "Template / interpolation strings",
      "scope": [
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#FFD98A"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape",
        "constant.character"
      ],
      "settings": {
        "foreground": "#FFE08A"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#FF9E4A"
      }
    },
    {
      "name": "Booleans / language constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#FF5C7A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants / enum members",
      "scope": [
        "constant.other",
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#FF9E4A"
      }
    },
    {
      "name": "Functions / method calls",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FFC978"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function.member",
        "meta.definition.function entity.name.function"
      ],
      "settings": {
        "foreground": "#FFD98A"
      }
    },
    {
      "name": "Classes / types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#FF9AC0"
      }
    },
    {
      "name": "Built-in types / primitives",
      "scope": [
        "support.type.primitive",
        "keyword.type",
        "storage.type.built-in"
      ],
      "settings": {
        "foreground": "#FF9AC0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#F0E0C8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#E0A882",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object keys / properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#FFCF9E"
      }
    },
    {
      "name": "Language built-in variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#FF5C7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "storage.type.operator"
      ],
      "settings": {
        "foreground": "#FFC96B"
      }
    },
    {
      "name": "Punctuation / delimiters",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7A6A50"
      }
    },
    {
      "name": "HTML / XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FF6B4A"
      }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFE08A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#FFC978"
      }
    },
    {
      "name": "CSS values / units",
      "scope": [
        "support.constant.property-value.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#E8C15A"
      }
    },
    {
      "name": "CSS classes / ids",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#FF9AC0"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#FFC978"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#FF6B4A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FF9E4A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#E8C15A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#FFC978",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown code / inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#FFD98A"
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#A89476",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#FFE08A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#FF8A6B"
      }
    },
    {
      "name": "Support / library functions",
      "scope": [
        "support.function.builtin",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFC96B"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF4D4D",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Imports / module paths",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#FF6B4A",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#FF9AC0",
    "class": "#FF9AC0",
    "class.declaration": "#FF9AC0",
    "interface": "#FFB0D0",
    "enum": "#FF9AC0",
    "enumMember": "#FF9E4A",
    "type": "#FF9AC0",
    "typeParameter": {
      "foreground": "#FF9AC0",
      "fontStyle": "italic"
    },
    "struct": "#FF9AC0",
    "function": "#FFC978",
    "function.declaration": "#FFD98A",
    "method": "#FFC978",
    "macro": "#FFE08A",
    "variable": "#F0E0C8",
    "variable.readonly": "#FF9E4A",
    "variable.declaration": "#F0E0C8",
    "parameter": {
      "foreground": "#E0A882",
      "fontStyle": "italic"
    },
    "property": "#FFCF9E",
    "property.readonly": "#FF9E4A",
    "keyword": "#FF6B4A",
    "string": "#E8C15A",
    "number": "#FF9E4A",
    "operator": "#FFC96B",
    "decorator": "#FFE08A",
    "*.deprecated": {
      "strikethrough": true
    }
  }
}
