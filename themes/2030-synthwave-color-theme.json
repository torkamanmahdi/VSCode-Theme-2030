  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#5E5290",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords / control flow",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type.function.arrow",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#FF3CA6"
      }
    },
    {
      "name": "Storage / modifiers",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF6EC7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#FFD866"
      }
    },
    {
      "name": "Template / interpolation strings",
      "scope": [
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#FFE58A"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape",
        "constant.character"
      ],
      "settings": {
        "foreground": "#FF8CC6"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#FF8B6B"
      }
    },
    {
      "name": "Booleans / language constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#FF6EC7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants / enum members",
      "scope": [
        "constant.other",
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#FF8B6B"
      }
    },
    {
      "name": "Functions / method calls",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#00E5FF"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function.member",
        "meta.definition.function entity.name.function"
      ],
      "settings": {
        "foreground": "#6BF0FF"
      }
    },
    {
      "name": "Classes / types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type",
        "entity.other.inherited-class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#C77DFF"
      }
    },
    {
      "name": "Built-in types / primitives",
      "scope": [
        "support.type.primitive",
        "keyword.type",
        "storage.type.built-in"
      ],
      "settings": {
        "foreground": "#C77DFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#E0D4FF"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FF9EDC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object keys / properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#7DE0FF"
      }
    },
    {
      "name": "Language built-in variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#FF6EC7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "storage.type.operator"
      ],
      "settings": {
        "foreground": "#72F1FF"
      }
    },
    {
      "name": "Punctuation / delimiters",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#6E5F9E"
      }
    },
    {
      "name": "HTML / XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FF3CA6"
      }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFD866",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#00E5FF"
      }
    },
    {
      "name": "CSS values / units",
      "scope": [
        "support.constant.property-value.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#FFD866"
      }
    },
    {
      "name": "CSS classes / ids",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#C77DFF"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#00E5FF"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#FF3CA6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FF8B6B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#FFD866",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#00E5FF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown code / inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#FFE58A"
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#9A8AC8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#FFD866",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#FF8CC6"
      }
    },
    {
      "name": "Support / library functions",
      "scope": [
        "support.function.builtin",
        "support.constant"
      ],
      "settings": {
        "foreground": "#72F1FF"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF4D6D",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Imports / module paths",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#FF3CA6",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#C77DFF",
    "class": "#C77DFF",
    "class.declaration": "#C77DFF",
    "interface": "#A88BFF",
    "enum": "#C77DFF",
    "enumMember": "#FF8B6B",
    "type": "#C77DFF",
    "typeParameter": {
      "foreground": "#C77DFF",
      "fontStyle": "italic"
    },
    "struct": "#C77DFF",
    "function": "#00E5FF",
    "function.declaration": "#6BF0FF",
    "method": "#00E5FF",
    "macro": "#FF8CC6",
    "variable": "#E0D4FF",
    "variable.readonly": "#FF8B6B",
    "variable.declaration": "#E0D4FF",
    "parameter": {
      "foreground": "#FF9EDC",
      "fontStyle": "italic"
    },
    "property": "#7DE0FF",
    "property.readonly": "#FF8B6B",
    "keyword": "#FF3CA6",
    "string": "#FFD866",
    "number": "#FF8B6B",
    "operator": "#72F1FF",
    "decorator": "#FFD866",
    "*.deprecated": {
      "strikethrough": true
    }
  }
}
